[flake8]
max-line-length = 100
max-complexity = 6
import-order-style = google
min-coverage-percents = 75

; max_function_length = 25
max_parameters_amount = 7
; max_returns_amount = 5

ignore =
    # E123 closing bracket does not match indentation of opening bracket's
    E123,
    # E126 continuation line over-indented for hanging indent
    E126,
    # D203 blank line required before class docstrin
    D203,
    # E221 multiple spaces before operator
    #E221,
    # E501 line too long (> 79 characters)
    E501,
    # W503 line break before binary operator
    W503,
    # W504 line break after binary operator
    ; W504,
    # F541 f-string is missing placeholders
    F541,
    # type annotations
    ; TAE001
    # print, pprint found
    T201, T203
exclude = .git,.vscode,__pycache__,env,venv,logs,zProjectDevelopment,old,build,dist,*.db,*.bat,*.exe,*.png,*.jpg,*.webm,*.mp4,*.mkv,*.wav,*.mp3,*.m4a,*.xml,*.csv,*.xls,*.xlsx,*doc,*docx,*.zip,*.txt

inline-quotes = '

# noqa
